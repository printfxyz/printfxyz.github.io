{
  "name": "html-tools-collector-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create html-tools-submissions",
    "db:migrate:local": "wrangler d1 migrations apply html-tools-submissions --local",
    "db:migrate:remote": "wrangler d1 migrations apply html-tools-submissions --remote",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260530.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.95.0"
  }
}
